{
	"name": "yeust-livechat-multitenant-example",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --hot src/index.ts",
		"typecheck": "bunx tsc --noEmit",
		"tailwind:build": "bunx @tailwindcss/cli -i ./src/tailwind.css -o ./src/index.css --minify",
		"build": "bun run tailwind:build && bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
		"start": "NODE_ENV=production bun src/index.ts"
	},
	"dependencies": {
		"react": "^19",
		"react-dom": "^19"
	},
	"devDependencies": {
		"@tailwindcss/cli": "^4.1.11",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@types/bun": "latest",
		"tailwindcss": "^4.1.11"
	}
}
